library(parallel) #for using multiple cores (mclapply for mac and linux, parLapply for windows)
# library(randomForest)
# library(lhs)

# load function
source("funcs/00_model_cluster.R")

# load in data
parm_mat <- readRDS("dat/mat_var_0922.Rdata")
head(parm_mat)
# for comparing simulations, grab the first 200 parameters and simulate them another 1000 times
# parm_mat <- parm_mat[1:200, ]
N <- dim(parm_mat)[1]

rep_num <- 500 # for gsa, run sets 200, 400, 400, 500x3 = 2500
rep_parm <- matrix(rep(t(parm_mat), rep_num), ncol = ncol(parm_mat), byrow = T)

# run functions across parm_mat
print("starting simulations")

gsa_result <- mclapply(1:(N*rep_num), function(i){
  
  case_vect <- rep_parm[i, c(1:34, 36)] # skip density dependence only, since that manipulates parameters when making the matrix
  
  cluster_run(case_vect) 
  
}, mc.cores = parallel::detectCores()) 

# save things!
saveRDS(gsa_result, file = paste0("dat/gsa_result_", format(Sys.time(), "%m%d"), ".Rdata"))
# saveRDS(gsa_result, file = paste0("dat/retest_gsa200_", format(Sys.time(), "%m%d"), ".Rdata"))

print("simulations complete")
