# Name: restoration_GSA
# Conduct GSA for intervention choices below, generates importance and decision tree plots, and saves full dataframe
#intervention cue, type of material reintroduced, theshold percentile of baseline, wait time
# Arguments:
#   n_samps: int, how many samples of intervention choices
#   n_sims: how many simulations to run for each set of intervention choices
#   clims: vector of strings, e.g., 'ssp126', which climate contexts to run simulations in?
#   grzs: vector of strings, e.g., 'low', 'med', 'high', which grazing contexts to run simulations in?
#   lhs: vector of strings, e.g., 'onlybank', which life history contexts to run simulations in?
#   dt: string, date label for saving materials with filenames and directory paths
# Output:
#   saves simulation output dataframe and decision tree and importance ranking plots
restoration_GSA <- function(n_samps, n_sims, clims, grzs, lhs, dt){
  ##########################################
  # Preparation
  
  # choose combo / context
  # clims <- c('ssp126', 'ssp585')
  # grzs <- c('low', 'med', 'high')
  # lhs <- c('onlybank', 'onlyage')
  combos <- expand.grid(clm=clims, grz=grzs, lh=lhs) # 12 combinations, 12 x 3 dataframe
  #print(combos$clm[1])
  #print(head(combos))
  
  # sample intervention cue
  cue_samples <- sample(c('A','J','G'), n_samps, replace=TRUE)
  # sample intervention type
  type_samples <- sample(c('M','J','D','MJD','MJ','JD','MD'), n_samps, replace=TRUE)
  #Sample percent effort
  eff_samples <- runif(n_samps, 0, 1)
  #Allocate effort across stages
  effM_samples <- effM_max * eff_samples #runif(n_samps, 0, 100)
  effJ_samples <- effJ_max * eff_samples #runif(n_samps, 0, 1000)
  effD_samples <- effD_max * eff_samples #runif(n_samps, 0, 1000)
  # sample percentile threshold 
  perc_samples <- sample(seq(0,0.5,0.005), n_samps, replace=TRUE) #runif(n_samps, 0, 0.5)
  # sample number of years to wait
  wait_samples <- sample(0:10, n_samps, replace=TRUE)
  
  # zero out the samples for which there is no intervention  
  # idc_no_interv <- which(cue_samples=='NONE')
  # effM_samples[idc_no_interv] <- 0
  # effJ_samples[idc_no_interv] <- 0
  # effD_samples[idc_no_interv] <- 0
  # perc_samples[idc_no_interv] <- 0
  # wait_samples[idc_no_interv] <- 150
  # type_samples[idc_no_interv] <- 'NONE'
  
  # zero out effort when not using that type of intervention
  idc_no_M <- which(type_samples=='J'| type_samples=='D'| type_samples=='JD')
  effM_samples[idc_no_M] <- 0
  idc_no_J <- which(type_samples=='M'| type_samples=='D'| type_samples=='MD')
  effJ_samples[idc_no_J] <- 0
  idc_no_D <- which(type_samples=='M'| type_samples=='J'| type_samples=='MJ')
  effD_samples[idc_no_D] <- 0
  print("Finished sampling")
  
  # calculate simulated historical baselines
  onlybank_baseline_info <- hist_sim(n_sims, n, lh='onlybank', nereo_vari_params, nereo_densdep_params, burnin=30)
  neither_baseline_info <- hist_sim(n_sims, n, lh='neither', nereo_vari_params, nereo_densdep_params, burnin=30)
  onlyage_baseline_info <- hist_sim(n_sims, n, lh='onlyage', macro_vari_params, macro_densdep_params, burnin=30)
  mixed_baseline_info <- hist_sim(n_sims, n, lh='mixed', macro_vari_params, macro_densdep_params, burnin=30)
  print("Finished calculating historical baselines")
  save(onlybank_baseline_info, file="sims_out/Q2_GSA/baselines/onlybank_baseline_info.Rdata")
  save(neither_baseline_info, file="sims_out/Q2_GSA/baselines/neither_baseline_info.Rdata")
  save(onlyage_baseline_info, file="sims_out/Q2_GSA/baselines/onlyage_baseline_info.Rdata")
  save(mixed_baseline_info, file="sims_out/Q2_GSA/baselines/mixed_baseline_info.Rdata")
  ################################
  # Simulations
  
  # prep for using multiple cores
  n_cores <- detectCores()
  print("Starting simulations")
  # sim_results is 12 dataframes (n_samps parameterizations x 12 variables (3 outcomes and 9 inputs))
  sim_results <- lapply(1:nrow(combos), function(i) apply_combos(n_sims, n_samps, n_cores, clm=combos$clm[i], grz=combos$grz[i], 
                                                                 lh=combos$lh[i], cue_samples, type_samples, eff_samples,
                                                                 effM_samples, effJ_samples, effD_samples, perc_samples, wait_samples, 
                                                                 onlybank_baseline_info, neither_baseline_info, 
                                                                 onlyage_baseline_info, mixed_baseline_info))
  #####################################
  # Remove variables from memory that aren't needed anymore
  rm(onlybank_baseline_info,onlyage_baseline_info,neither_baseline_info,mixed_baseline_info)
  rm(cue_samples,type_samples,effM_samples,effJ_samples,effD_samples,perc_samples,wait_samples)
  #rm(nereo_vari_params, nereo_densdep_params, macro_vari_params, macro_densdep_params)
  ####################################
  # Organizing output
  
  # put the 12 dataframes together
  df_all <- bind_rows(sim_results)
  # save the big dataframe
  #print(paste0("dimensions of df_all: ", dim(df_all)))
  save(df_all, file = paste0("sims_out/Q2_GSA/sampled_sims/AllOutcomes_w_ParamSamples_", dt, ".Rdata"))
  # collect all dataframes together, 12 context-dependent ones and 1 big dataframe
  sim_results[[length(sim_results)+1]] <- df_all
  print(length(sim_results))
  # save 13 sets of 8 plots (importance bars and decision tree for each outcome)
  print("Running random forest")
  lapply(sim_results, function(x) subset_rf_plot(x, dt, n_samps)) 
}


