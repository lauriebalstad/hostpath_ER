# Name: restoration_season
# Runs a seasonal update and flags when a restoration cue is met
# Arguments:
#   lh: string, "onlybank", "onlyage", "neither" or "mixed"
#   X_ts: matrix (16x4n+1), timeseries of biomass stage distribution
#   gD_ts: vector (4n), timeseries of grazing rates on drift kelp
#   idx: starts from 1, the year in the simulation that we are working on
#   graz_params: dictionary including k, g, epsilon, p_M, p_J, p_A
#   year_params: dictionary (4), time-dependent demographic variables for 4 seasons in the current  year-type
#   dens_dep_params: dictionary including alpha, beta_M, beta_J, beta_A
#   flag: bool, to restore or not to restore, TRUE if there was a flag thrown in the previous year
#   cue: string, 'A' - adult biomass cue, 'J' - juvenile biomass cue, 'G' - grazing cue, 'NONE' - no intervention 
#   sampled_interv_params: vector (5), containing M_eff, J_eff, D_eff, perc, wait
#   s: int, indicates which season we're working on, 1 - spring, 2 - summer, 3 - fall, 4 - winter
# Returns:
#   list containing:
#   X_ts: matrix (16x4n+1), updated timeseries of biomass distribution
#   gD_ts: vector (4n), updated timeseries of grazing rates on drift kelp
#   flag: bool, TRUE if a cue was triggered this year
restoration_season <- function(lh, X_ts, gD_ts, year_params, dens_dep_params, 
                               flag, cue, sampled_interv_params, s, hist_baseline_info){
  # previous timestep
  t_end <- which(colSums(is.na(X_ts)) > 0)[1] - 1 # the column before the fist column that is NA
  X <- X_ts[,t_end]
  
  # pull out previous wndo years for threshold calculations
  # t_start <- t_end-(sampled_interv_params[4]*4)+1 # let's say t_end=9, idx=3, wndo=2, then t_start=2 (spring)
  # if (t_start<=0){t_start<-1}
  # X_wndo <- X_ts[,t_start:t_end]
  # g_wndo <- gD_ts[t_start-1:t_end-1] # starts from 1 while X_ts starts from 2
  
  # run seasonal update
  new_info <- season(lh, graz_params, year_params[[s]], dens_dep_params, X, s)
  X <- new_info[[1]]
  X_ts[,t_end+1] <- X # save it into complete timeseries
  g <- new_info[[4]][4] # g_vec[4] is g_D
  gD_ts[t_end] <- g
  
  # throw flags for intervention next spring
  # for cue 'J', record whether J<threshold, throw flag to intervene at start of spring next year if so
  if (cue=='J' & s==1){
    # calculate threshold as perc percentile of springtime juveniles (row 8) in past wndo years
#    past_J <- X_wndo[8,]
    # if (idx>3){
    #   # after there's more than 2 springtimes, pick out just the springtime columns to include in this threshold calculation
    #   # X_wndo ends with winter and begins with spring. 1,2,3,4. if idx>3, use only spring: 1 to ncol-3, every 4
    #   past_J <- X_wndo[8,seq(1,ncol(X_wndo)-3,4)]
    # }
    if (X[8]<=quantile(hist_baseline_info[[2]], sampled_interv_params[4])){ 
      flag<-TRUE
    }
    else{flag<-FALSE} # put the flag down
  }
  # for cue 'A', record whether A<threshold, throw flag to intervene at start of spring next year if so
  else if (cue=='A' & s==2){
    # past_A <- colSums(X_wndo[9:15,])
    # if (idx>3){
    #   # after there's more than 2 summertimes, pick out just the summertime columns to include in this threshold calculation
    #   past_A <- past_A[seq(2,length(past_A)-2,4)] # X_wndo ends with winter and begins with spring. 1,2,3,4. 2 to ncol-2, every 4
    # }
    if (sum(X[9:15])<=quantile(hist_baseline_info[[1]], sampled_interv_params[4])){ 
      flag<-TRUE
    }
    else{flag<-FALSE} # put the flag down
  }
  # for cue 'G', record whether g_D<threshold, throw flag to intervene at start of spring next year if so
  else if (cue=='G'){
    if (g<=quantile(hist_baseline_info[[3]], sampled_interv_params[4])){
      flag<-TRUE
    }
    else{flag<-FALSE} # put the flag down
  }
  
  # if (t_end%%10==0){
  #   print(X_ts)
  # }
  
  return(list(X_ts, gD_ts, flag))
}  

# Name: restoration year
# Runs model for 4 seasons (Spring-Spring), with intervention
# Arguments:
#   lh: string, "onlybank", "onlyage", "neither" or "mixed"
#   X_ts: matrix (16x4n+1), timeseries of biomass stage distribution
#   gD_ts: vector (4n), timeseries of grazing rates on drift kelp
#   idx: starts from 1, the year in the simulation that we are working on
#   graz_params: dictionary including k, g, epsilon, p_M, p_J, p_A
#   year_params: dictionary (4), time-dependent demographic variables for 4 seasons in the current  year-type
#   dens_dep_params: dictionary including alpha, beta_M, beta_J, beta_A
#   flag: bool, to restore or not to restore, TRUE if there was a flag thrown in the previous year
#   cue: string, 'A' - adult biomass cue, 'J' - juvenile biomass cue, 'G' - grazing cue, 'NONE' - no intervention 
#   sampled_interv_params: vector (5), containing M_eff, J_eff, D_eff, perc, wait
#   num_interv_yrs: int, running counter for how many years of intervention have accumulated over the simulation
# Returns:
#   list containing:
#   X_ts: matrix (16x4n+1), updated timeseries of biomass distribution
#   gD_ts: vector (4n), updated timeseries of grazing rates on drift kelp
#   flag: bool, TRUE if a cue was triggered this year
#   num_interv_years: int, updated number of spring seasons undergoing intervention
restoration_year <- function(lh, X_ts, gD_ts, year_params, dens_dep_params, #idx, 
                             flag, cue, sampled_interv_params, num_interv_yrs, 
                             num_flag_yrs, hist_baseline_info, idx, burnin){
  #print(paste0('flag at top of year: ', flag))
  #print(paste0('num_interv_yrs at top of year: ', num_interv_yrs)) # this doesn't
  #print(paste0('num_flag_yrs at top of year: ', num_flag_yrs)) # this counts up
  
  # previous timestep
  t_end <- which(colSums(is.na(X_ts)) > 0)[1] - 1 # the column before the fist column that is NA
 # X <- X_ts[,t_end]
  
  # Add to wait time counter if restoration cue was flagged in the previous year
  if (flag==TRUE){
    num_flag_yrs <- num_flag_yrs+1
  }
  
  #print(is.na(flag))
  #print(is.na(num_flag_yrs))
  
  # Run intervention if cue has been flagged for wait years
  if (num_flag_yrs==sampled_interv_params[5] & cue!='NONE' ){
    X_ts[,t_end] <- X_ts[,t_end] + c(sampled_interv_params[1],0,0,0,0,0,0,sampled_interv_params[2],0,0,0,0,0,0,0,sampled_interv_params[3])
    num_flag_yrs <- 0 # reset counter
    if (idx>burnin){ # start counting the intervention years after burnin
      num_interv_yrs <- num_interv_yrs+1
    }
    #print("intervened this year!")
  }
  
  # apply seasons
  for (s in 1:4){
    update <- restoration_season(lh, X_ts, gD_ts, year_params, dens_dep_params, 
                                 flag, cue, sampled_interv_params, s, hist_baseline_info)
    X_ts <- update[[1]]
    gD_ts <- update[[2]]
    flag <- update[[3]]
  }
  
  return(list(X_ts, gD_ts, flag, num_interv_yrs, num_flag_yrs))
}  

# Name: restoration_sim
# Runs model for many years and produce time series of stage distribution
# Arguments:
#   lh: string, "onlybank", "onlyage", "neither" or "mixed"
#   vari_params: dictionary (3), season-dependent demographic variables for 3 year-types. Each dictionary contains 4 seasons in the respective year-type
#   dens_dep_params: dictionary including alpha, beta_M, beta_JA
#   years: vector (n) of integers indicating year types: 1 good, 2 neural, 3 bad
#   cue: string, 'A' - adult biomass cue, 'J' - juvenile biomass cue, 'G' - grazing cue, 'NONE' - no intervention 
#   sampled_interv_params: vector (5), containing M_eff, J_eff, D_eff, perc, wait
#   burnin: int, number of years to cut out of beginning of simulation results
#   hist_baseline_info: list or bool, list of n_sims outcomes in historical scenario, FALSE if not taking in baselines
# Returns:
#   list containing:
#     1. Final fall microscopic biomass
#     2. Final summer adult biomass
#     3. Final spring juvenile biomass
#     4. 1/CV for live kelp biomass
#     5. proportion of years above threshold (if hist_baseline_info is not FALSE)
#     6. number of intervention years
#     7. realized grazing rate on drift kelp
restoration_sim <- function(lh, vari_params, dens_dep_params, 
                            years, cue, sampled_interv_params, burnin, hist_baseline_info){
  #print(years)
  
  # Make containers for biomasses and grazing over time
  X_ts <- matrix(nrow=16, ncol=1+(n*4))
  X_ts[,1] <- X_init # initialize with initial biomasses
  gD_ts <- vector(length=4*n)
  # Make a counter for restoration years
  num_interv_yrs <- 0
  # Set initial flag status, we will not intervene in 1st year
  flag <- FALSE
  # Tracking number of years the flag has been thrown
  num_flag_yrs <- 0
  
  # Loop through years
  for (idx in 1:n){
    yr <- years[idx]
    #print(paste0("flag at top of year: ", flag))
    update <- restoration_year(lh, X_ts, gD_ts, vari_params[[yr]], dens_dep_params, 
                               flag, cue, sampled_interv_params, num_interv_yrs, num_flag_yrs, 
                               hist_baseline_info, idx, burnin)
    # Populate data structures
    X_ts <- update[[1]]
    gD_ts <- update[[2]]
    flag <- update[[3]]
    num_interv_yrs <- update[[4]] # conditional, num_interv_yrs increases only after idx>burnin
    num_flag_yrs <- update[[5]]
  }
  
  df <- summary(X_ts, years, n)
  #print(tail(df)) # looks good
  metrics <- restoration_outcomes(df, burnin, hist_baseline_info)
  #print(metrics)
  out <- append(metrics, num_interv_yrs)
  out <- append(out, mean(gD_ts)) 
  
  # if hist_baseline_info are the baseline lists, then out is
  # Mfal, Asum, Jspr, 1/cv, persist, num_interv_yrs, gD
  
  # if hist_baseline_info is FALSE, then out is
  # Mfal, Asum, Jspr, 1/cv, num_interv_yrs, gD
  
  return(out)
}

