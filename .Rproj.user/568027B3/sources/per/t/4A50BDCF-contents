# Name: restoration_sims_LSA
# Applies a single parameter value, runs and summarizes n_sims stochastic simulations
# Arguments:
#   param_name: string, the parameter to sweep
#   param_val: double, the sampled value of the parameter of interest
#   lh: string, 'onlybank', 'neither', 'onlyage', 'mixed'
#   vari_params: list (3) of demographic parameters for good, neutral, and bad years
#   n_sims: int, number of simulations to run per parameter sample
#   clim: string, 'ssp126', 'ssp245', 'ssp370', 'ssp585'
#   cue: string, 'A' - summer adult biomass, 'G' - realized grazing, 'J' - spring juvenile biomass, 'NONE' - no intervention
#   interv_params: vector (5), containing M_eff, J_eff, D_eff, perc, wait
#   hist_baseline_info: list (4), baseline Asum, Jspr, lambda, gD
# Output:
#   list of 5: Mfal, Asum, Jspr, persist, numyrs
restoration_sims_LSA <- function(param_name, param_val, lh, vari_params, dens_dep_params,
                                 n_sims, clim, cue, interv_params, hist_baseline_info){
  # pull apart vari_params to adjust banking, recruitment, fecundity
  neut <- vari_params[[2]]
  spr <- neut[[1]]
  sum <- neut[[2]]
  fal <- neut[[3]]
  win <- neut[[4]]
  # assign the parameter value
  if (param_name=='d_J'){
    spr[[5]] <- param_val
    sum[[5]] <- param_val
    fal[[5]] <- param_val
    win[[5]] <- param_val
  }
  if (param_name=='d_M'){
    if (lh=='onlybank' | lh=='onlyage'){
      spr[[1]] <- param_val
      sum[[1]] <- param_val
      fal[[1]] <- param_val
      win[[1]] <- param_val
    }
    if (lh=='mixed' | lh=='neither'){
      spr[[2]] <- param_val
      sum[[2]] <- param_val
      fal[[2]] <- param_val
      win[[2]] <- param_val
    }
  }
  if (param_name=='g'){
    graz_params[['g']] <- param_val
  }
  # put vari_params back together
  neut <- list(spr,sum,fal,win)
  vari_params[[2]] <- neut
  vari_params[[3]] <- bad(neut, knock)
  vari_params[[1]] <- good(neut)
  # make n_sims years sequences
  if (param_name=='phi'){
    if (clim=='hist'){
      env_params_hist[[1]] <- param_val
    }
    else if (clim=='ssp126'){
      env_params_126[[1]] <- param_val
    }
    else if (clim=='ssp245'){
      env_params_245[[1]] <- param_val
    }
    else if (clim=='ssp370'){
      env_params_370[[1]] <- param_val
    }
    else if (clim=='ssp585'){
      env_params_585[[1]] <- param_val
    }
  }
  envs <- many_env_ts(n_sims, clim, n) 
  
  # run n_sim simulations for this parameterization
  # is this function call how I want it? yes!
  sim_results <- restoration_stoch_sims(lh, vari_params, dens_dep_params, envs, cue, 
                         interv_params, return_type='LSA', burnin=30, hist_baseline_info)
  # Note: each parameter sample will get a different set of n_sims year-type sequences - 
  # this is different from the GSA, where all samples within the same combo/context got the same n_sims sequences
  
  return(sim_results) # list of 5: Mfal, Asum, Jspr, persist, numyrs
}

# trial run this and see dataframe, biomasses look good
# Sweeps over parameter of interest and returns dataframe with parameter value and outcome metrics
restoration_LSA <- function(param_name, param_min, param_max, lh,
                            n_samps, n_sims, clim, cue, interv_params, dt){
  # set species parameters
  vari_params <- c()
  dens_dep_params <- c()
  if (lh=='onlybank'|lh=='neither'){
    vari_params <- nereo_vari_params
    dens_dep_params <- nereo_densdep_params
  }
  else if (lh=='onlyage'|lh=='mixed'){
    vari_params <- macro_vari_params
    dens_dep_params <- macro_densdep_params
  }
  
  # load historical baselines
  hist_baseline_info <- c()
  if (lh=='onlybank'){
    load("sims_out/Q2_GSA/baselines/onlybank_baseline_info.Rdata")
    hist_baseline_info <- onlybank_baseline_info
  }
  if (lh=='neither'){
    load("sims_out/Q2_GSA/baselines/neither_baseline_info.Rdata")
    hist_baseline_info <- neither_baseline_info
  }
  if (lh=='onlyage'){
    load("sims_out/Q2_GSA/baselines/onlyage_baseline_info.Rdata")
    hist_baseline_info <- onlyage_baseline_info
  }
  if (lh=='mixed'){
    load("sims_out/Q2_GSA/baselines/mixed_baseline_info.Rdata")
    hist_baseline_info <- mixed_baseline_info
  }
  
  #print(length(hist_baseline_info))
  #print(hist_baseline_info)
  
  # sample the parameter of interest
  param_samples <- runif(n_samps, param_min, param_max)
  
  # prep for using multiple cores
  n_cores <- detectCores()
  print("Starting simulations")
  
  # simulate over n_samps param_samples  
  sim_results <- mclapply(1:n_samps, function(i){ # over the n_samps parameter samples,
    # run n_sims unique simulations and report the 5 summary variables for each sample.
    restoration_sims_LSA(param_name, param_val=param_samples[i], lh, vari_params, dens_dep_params,
                         n_sims, clim, cue, interv_params, hist_baseline_info)
    }, mc.cores = n_cores-1)
  # sim_results is n_samps lists of 5 summary variables (summarized over n_sims stochastic runs)
      
  # parse out outcomes into vectors of length n_samps
  Mfal_results <- mapply(function(x) x[1], sim_results)
  Asum_results <- mapply(function(x) x[2], sim_results)
  Jspr_results <- mapply(function(x) x[3], sim_results)
  persist_results <- mapply(function(x) x[4], sim_results)
  numyrs_results <- mapply(function(x) x[5], sim_results)
  
  # remove sim_results from memory after collecting info of interest
  rm(sim_results)
  
  # save parameterizations with outcome metrics, columns are variables, rows are parameterizations
  df <- data.frame(param_val=param_samples, lhs=rep(lh, n_samps), clims=rep(clim, n_samps),
                   Mfal=unlist(Mfal_results), Jspr=unlist(Jspr_results), Asum=unlist(Asum_results), #cv=unlist(cv_results), lambda=unlist(lambda_results),
                   persist=unlist(persist_results), numyrs=unlist(numyrs_results)) 
  save(df, file = paste0('sims_out/Q2_GSA/LSA/', lh, '_', clim, '_', cue, '_', param_name, '_', dt, '.Rdata'))
  print('saved simulation outcome dataframe')
  
  return(df)  
}




