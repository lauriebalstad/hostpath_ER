# Make n_sims timeseries
many_env_ts <- function(n_sims, clim, n){
  sequences <- list()
  
  if (clim=='hist') {
    sequences <- lapply(seq_len(n_sims), function(x) 
      TPM_env_ts(n, env_params_hist[[1]], env_params_hist[[2]], 
                 env_params_hist[[3]], env_params_hist[[4]], env_params_hist[[5]]))
  }
  else if (clim=='ssp126') {
    sequences <- lapply(seq_len(n_sims), function(x) 
                        TPM_env_ts(n, env_params_126[[1]], env_params_126[[2]], 
                                   env_params_126[[3]], env_params_126[[4]], env_params_126[[5]]))
  }
  else if (clim=='ssp245') {
    sequences <- lapply(seq_len(n_sims), function(x) 
      TPM_env_ts(n, env_params_245[[1]], env_params_245[[2]], 
                 env_params_245[[3]], env_params_245[[4]], env_params_245[[5]]))
  }
  else if (clim=='ssp370') {
    sequences <- lapply(seq_len(n_sims), function(x) 
      TPM_env_ts(n, env_params_370[[1]], env_params_370[[2]], 
                 env_params_370[[3]], env_params_370[[4]], env_params_370[[5]]))
  }
  else if (clim=='ssp585') {
    sequences <- lapply(seq_len(n_sims), function(x) 
      TPM_env_ts(n, env_params_585[[1]], env_params_585[[2]], 
                 env_params_585[[3]], env_params_585[[4]], env_params_585[[5]]))
  }
  
  return(sequences)
}

# Name: restoration_stoch_sims
# Iterate sim for 100 different years timeseries
# Arguments:
#   envs: list (length of n_sims), yeartype sequences all generated from same climate scenario
#   return_type: string, 'GSA', 'LSA', or 'hist_baseline', indicates which set of outcomes to return
#   everything that restoration_sim() needs
# Output:
#   list containing outcome metrics, see code below for specifics depending on return_type
restoration_stoch_sims <- function(lh, vari_params, dens_dep_params, envs, cue, 
                                   sampled_interv_params, return_type, burnin, hist_baseline_info){
  sim_results <- lapply(seq_len(length(envs)), function(i)
    restoration_sim(lh, vari_params, dens_dep_params, 
                    years=envs[[i]], cue, sampled_interv_params, burnin, hist_baseline_info))
  
  # summarize results
  Mfal_results <- unlist(mapply(function(x) x[1], sim_results))
  Asum_results <- unlist(mapply(function(x) x[2], sim_results)) # length is n_sims
  Jspr_results <- unlist(mapply(function(x) x[3], sim_results))
  cv_results <- unlist(mapply(function(x) x[4], sim_results))
  persist_results <- c()
  numyrs_results <- c()
  gD_results <- c()
  persist <- numeric()
  if (hist_baseline_info != FALSE){
    persist_results <- unlist(mapply(function(x) x[5], sim_results))
    persist <- mean(persist_results)
    numyrs_results <- unlist(mapply(function(x) x[6], sim_results))
    gD_results <- unlist(mapply(function(x) x[7], sim_results))
  }
  else{
    numyrs_results <- unlist(mapply(function(x) x[5], sim_results))
    gD_results <- unlist(mapply(function(x) x[6], sim_results))
  }
  
  # remove sim_results from memory after collecting info of interest
  rm(sim_results)
  
  Mfal <- mean(Mfal_results)
  Asum <- mean(Asum_results)
  Jspr <- mean(Jspr_results)
  cv <- mean(cv_results)
  #lambda <- mean(lambda_results)
  #prop_persist <- sum(lambda_results>=0.995)/length(lambda_results)
  numyrs <- mean(numyrs_results)
  
  # if doing hist baseline sim, return one thing
  if (return_type=='hist_baseline'){
    return(list(Asum_results, Jspr_results, gD_results))
  }
  else if (return_type=='GSA'){
    return(list(Asum, cv, persist, numyrs))
  }
  else if (return_type=='LSA'){
    return(list(Mfal, Asum, Jspr, persist, numyrs))   
  }
}

# Calculate simulated historical baselines for restoration
hist_sim <- function(n_sims, n, lh, vari_params, dens_dep_params, burnin){
  envs <- many_env_ts(n_sims, clim='hist', n)
  # run stochastic sims -> Collect final Asum, Jspr, g_D
  results <- restoration_stoch_sims(lh, vari_params, dens_dep_params, envs, 
                                    cue='NONE', sampled_interv_params=c(0,0,0,0,0), 
                                    return_type='hist_baseline', burnin, hist_baseline_info=FALSE)
  return(results) # final Asum for each sim, final Jspr for each sim, average gD for each sim
}
