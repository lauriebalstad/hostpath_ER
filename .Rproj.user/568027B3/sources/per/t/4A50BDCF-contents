# Takes clm and makes envs
# Takes grz and replaces g in graz_params
# Takes lh and decides which param dictionaries to pass to restoration_stoch_sims
# returns dataframe (n_samps+1 rows) containing Asum, improve, persist, num_yrs, summarized for n_sims simulations each
apply_combos <- function(n_sims, n_samps, n_cores, clm, grz, lh, cue_samples, type_samples, eff_samples,
                         effM_samples, effJ_samples, effD_samples, perc_samples, wait_samples, 
                         onlybank_hist_baseline, neither_hist_baseline, onlyage_hist_baseline, mixed_hist_baseline){
  # report progress
  print(paste0("climate: ", clm, "  grazing: ", grz, "  life history: ", lh))
  
  # set climate
  envs <- many_env_ts(n_sims, clm, n) 
  
  # Set grazing pressure
  if (grz=="low"){graz_params[['g']] <- 0.105} # 90% ungrazed
  else if (grz=="med"){graz_params[['g']] <- 1.204} # 30% ungrazed
  else if (grz=="high"){graz_params[['g']] <- 2.996} # 5% ungrazed
  
  # set species parameters
  vari_params <- c()
  densdep_params <- c()
  hist_baseline_info <- c()
  if (lh=='onlybank'|lh=='neither'){
    vari_params <- nereo_vari_params
    densdep_params <- nereo_densdep_params
    if (lh=='onlybank'){ hist_baseline_info <- onlybank_hist_baseline}
    else if (lh=='neither'){ hist_baseline_info <- neither_hist_baseline}
  }
  else if (lh=='onlyage'|lh=='mixed'){
    vari_params <- macro_vari_params
    densdep_params <- macro_densdep_params
    if (lh=='onlyage'){ hist_baseline_info <- onlyage_hist_baseline}
    else if (lh=='mixed'){ hist_baseline_info <- mixed_hist_baseline}
  }
  
  # run the no intervention case in this lh-grz-clim context
  nointerv_results <- restoration_stoch_sims(lh, vari_params, densdep_params, envs, cue='NONE', 
                                             sampled_interv_params=c(0,0,0,0,120), 
                                             return_type='GSA', burnin=30, hist_baseline_info)
  nointerv_df <- data.frame(Asum=nointerv_results[1], persist=nointerv_results[3], numyrs=nointerv_results[4], 
                            clims=as.factor(clm), grzs=as.factor(grz), lhs=as.factor(lh), 
                            cue=as.factor('NONE'), type=as.factor('NONE'), eff=0,
                            effM=0, effJ=0, effD=0, perc=0, wait=120)
  # run intervention sims!
  print(paste0("finished context setup; using ", n_cores, " cores for ", n_samps, " samples"))
  sim_results <- mclapply(1:n_samps, function(i){ # over the n_samps parameter samples,
    # run 100 unique simulations and report the 5 summary variables for each sample.
    restoration_stoch_sims(lh, vari_params, densdep_params, envs, cue=cue_samples[i], 
                           sampled_interv_params=c(effM_samples[i],effJ_samples[i],effD_samples[i],perc_samples[i],wait_samples[i]), 
                           return_type='GSA', burnin=30, hist_baseline_info)
  }, mc.cores = n_cores-1) # save 1 core for system operations
  # sim_results is n_samps lists of outcome metrics, summarized across n_sims sims each
  #print("Finished simulations, organizing results")
  
  # parse out outcomes into vectors of length n_samps
  Asum_results <- mapply(function(x) x[1], sim_results)
  #cv_results <- mapply(function(x) x[2], sim_results)
  pesist_results <- mapply(function(x) x[3], sim_results)
  numyrs_results <- mapply(function(x) x[4], sim_results)
  
  # remove sim_results from memory after collecting info of interest
  rm(sim_results)

  # save parameterizations with outcome metrics, columns are variables, rows are parameterizations
  interv_df <- data.frame(Asum=unlist(Asum_results), #cv=unlist(cv_results), lambda=unlist(lambda_results),
                   persist=unlist(persist_results), numyrs=unlist(numyrs_results), 
                   clims=rep(as.factor(clm), n_samps), grzs=rep(as.factor(grz), n_samps), 
                   lhs=rep(as.factor(lh), n_samps), cue=as.factor(cue_samples), 
                   type=as.factor(type_samples), eff=eff_samples, effM=effM_samples, effJ=effJ_samples, 
                   effD=effD_samples, perc=perc_samples, wait=wait_samples)
  df <- bind_rows(nointerv_df, interv_df) # add the no intervention run
  # add column for improvement compared to no_interv runs in this context
  improve <- (df$Asum - nointerv_results[1]) / nointerv_results[1]
  add_column(df, improve, .after = "Asum")
  
  return(df) 
}


subset_rf_plot <- function(df, dt, n_samps){
  # pull out context labels
  clm= "all_clm"
  grz="all_grz"
  lh="all_lh"
  
  # drop the effort columns from GSA, because they confound with type
  df <- df[, -which(names(df)=="effM" | names(df)=="effJ" | names(df)=="effD")]
  
  if (nrow(df)==n_samps){ # if we're using one of the 12 context-specific dataframes
    clm <- as.character(df$clims[1])
    grz <- as.character(df$grzs[1])
    lh <- as.character(df$lhs[1])
    # drop the label from the dataframe so it's not used in random forest
    df <- df[, -which(names(df)=="clims" | names(df)=="grzs" | names(df)=="lhs")]
  }
  #print(paste0("dimensions of df: ", dim(df))) # n_samps x 10
  
  # remove no intervention cases from dataframe to focus on: if there was intervention, what decisions mattered?
  # intervention choices in cue 'NONE' confound the regression b/c they're redundant with "cue" and not actually used in the simulations
  df <- df[-which(df$cue=='NONE'), ]
  if (sum(is.na(df))>0){
    stop(paste0("Encountered NA in randomForest input for ", clm, " ", grz, " ", lh))
  }
  
  # pull out the outcomes separately
  df_Asum <- df[, -which(names(df)=="persist" | names(df)=="numyrs" | names(df)=="improve")]
  df_improve <- df[, -which(names(df)=="persist" | names(df)=="numyrs" | names(df)=="Asum")]
