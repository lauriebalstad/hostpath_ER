  df_numyrs <- df[, -which(names(df)=="persist" | names(df)=="Asum" | names(df)=="improve")]
  
  # run random forest analysis for outcome against restoration choices
  RF_Asum <- randomForest(Asum~.,data=df_Asum,importance=TRUE,type='regression')#, proximity=TRUE)
