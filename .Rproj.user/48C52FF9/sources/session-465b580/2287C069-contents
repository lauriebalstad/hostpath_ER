                            pop_size_tf_all = mean(r_all_30$pop_size_tf_all),
                            time_first_at_K = mean(r_all_30$time_first_at_K, na.rm = T),
                            infect_class_I_tf_all = mean(r_all_30$infect_class_I_tf_all),
