RF_class <- merge(as.data.frame(random_parms), sim_dat, by.x = "V36", by.y = "parm_number")
RF_class <- merge(RF_class, bd_parms, by.x = "V36", by.y = "number")
colnames(RF_class) <- c("parameter number", "compartments", "event order",
"\u03B2_F,RR", "\u03B2_F,WR", "\u03B2_F,WW", "\u03C3_\u03B2,F",
"\u03B2_D,RR", "\u03B2_D,WR", "\u03B2_D,WW", "\u03C3_\u03B2,D",
"\u03BC_S,RR", "\u03BC_S,WR", "\u03BC_S,WW", "\u03BC_I,RR", "\u03BC_I,WR", "\u03BC_I,WW", "\u03C3_\u03BC,S", "\u03C3_\u03BC,I",
"\u03B3_RR", "\u03B3_WR", "\u03B3_WW", "\u03C3_\u03B3",
"\u03BB_RR", "\u03BB_WR", "\u03BB_WW", "\u03BB_sd", "\u03BD",
"K", "\u03C3_K",
"t_q", "d",
"Q_0", "I_0", "t_f", "transmission case", "adaptive pathway", colnames(RF_class[38:68]))
# note the the variables that are categorical
RF_class$"compartments" <- as.factor(RF_class$"compartments")
RF_class$"event order" <- as.factor(RF_class$"event order")
RF_class$"transmission case" <- as.factor(RF_class$"transmission case")
RF_class$"adaptive pathway" <- as.factor(RF_class$"adaptive pathway")
RF_class$ER <- ifelse(RF_class$extinct == 0 &
abs(RF_class$last_50-RF_class$first_50-RF_class$tot_50) <3 &
RF_class$tot_50 > 3 &
RF_class$at_K95 == 1 &
RF_class$r_allele_peak45 == 1,
1, 0) # <0.1% of sims
RF_class$IL <- ifelse(RF_class$extinct == 0 &
abs(RF_class$last_50-RF_class$first_50-RF_class$tot_50) <3 &
RF_class$tot_50 > 3 &
RF_class$at_K95 == 1 &
RF_class$r_allele_peak45 == 0 &
RF_class$final_inf_prev == 0,
1, 0) # ~10% of sims
# have extinction column already
RF_class$EX <- RF_class$extinct # ~45%
RF_class$NR <- ifelse(RF_class$extinct == 0 & RF_class$tot_50 < 3, 1, 0) # ~25%
RF_class$clss <- ifelse(RF_class$extinct == 1, "extinct",
ifelse(RF_class$ER == 1, "ER",
ifelse(RF_class$IL == 1, "IL",
ifelse(RF_class$NR == 1, "NR", "UNK")))) # ~20% unknowns
RF_class$clss <- as.factor(RF_class$clss)
pred_vars <- c(2, 3, 6, 10, 14, 17, 22, 26, 28:30, 32, 34, 36, 37, 66, 67, 68)
colnames(RF_class)[pred_vars]
forest_class <- randomForest(y=RF_class$clss, x=RF_class[, pred_vars], ntree=50, importance = T, localImp = T, type = "classification")
forest_class
plot(forest_class)
importance(forest_class)
rpart(y=RF_class$clss, x=RF_class[, pred_vars], method = "anova")
