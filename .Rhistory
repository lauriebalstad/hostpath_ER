cb_il_A <- cb_dtf_A %>% filter(extinct == 0 & abs(last_50-first_50-tot_50) <3 & tot_50 > 3 & at_K95 == 1 & r_allele_peak45 == 0 & final_inf_prev == 0) %>% group_by(parm_number) %>% summarise(`P(IL) - A` = n()/1000)
cb_il_B <- cb_dtf_B %>% filter(extinct == 0 & abs(last_50-first_50-tot_50) <3 & tot_50 > 3 & at_K95 == 1 & r_allele_peak45 == 0 & final_inf_prev == 0) %>% group_by(parm_number) %>% summarise(`P(IL) - B` = n()/1000)
# cb_il_C <- cb_dtf_C %>% filter(extinct == 0 & abs(last_50-first_50-tot_50) <3 & tot_50 > 3 & at_K95 == 1 & r_allele_peak45 == 0 & final_inf_prev == 0) %>% group_by(parm_number) %>% summarise(`P(IL) - C` = n()/1000)
cb_il <- merge(cb_il_A, cb_il_B, by = "parm_number", all = T)
# cb_il <- merge(cb_il, cb_il_C, by = "parm_number", all = T)
cb_il$diff_1 <- ifelse(is.na(cb_il$`P(IL) - A`), 0, cb_il$`P(IL) - A`) - ifelse(is.na(cb_il$`P(IL) - B`), 0, cb_il$`P(IL) - B`)
# cb_il$diff_2 <- ifelse(is.na(cb_il$`P(IL) - A`), 0, cb_il$`P(IL) - A`) - ifelse(is.na(cb_il$`P(IL) - C`), 0, cb_il$`P(IL) - C`)
# cb_il$diff_3 <- ifelse(is.na(cb_il$`P(IL) - C`), 0, cb_il$`P(IL) - C`) - ifelse(is.na(cb_il$`P(IL) - B`), 0, cb_il$`P(IL) - B`)
fig_il <- rbind(str_il, pm_il, dc_il, cb_il)
