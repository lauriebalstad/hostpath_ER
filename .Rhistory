geom_line(data = all_ts_long %>% filter(trial == 6), aes(color = "Extinction"), lwd = 0.85) + # extinction
geom_line(data = all_ts_long %>% filter(trial == 9), aes(color = "Persist. ER"), lwd = 0.85) + # ER
