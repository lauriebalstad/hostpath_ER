legend.title = element_text(size = 10.5),
legend.position = "bottom",
axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1))
png("figs/figure_plot/SUPP_fullimp_0220.png",height=100,width=170,res=400,units='mm')
print(figS3)
