sis_cb <- expand.grid("benefit" = c(0, 0.25, 0.5, 1), # 0 = total benefit, 1.5 = some cost for B & M, but opposite for G
"cost" = c(1.7, 2.1), # 1.7 = some cost, 2.1 = no cost
# "cost" = c(1.1, 1.9, 2.1), # 1 = some cost, 2 = no cost
"case" = c("\u03b2", "\u03bc", "\u03d2"),
"compartments" = c(2))
# "compartments" = c(2))
N <- dim(sis_cb)[1]
sis_cb$number <- 1:N
# replace clearance-augmenting 0 benefit w 0.05 rows 25 & 29
sis_cb$benefit[c(17, 21)] <- 0.05
rep_num <- 1000 # 1 = testing run time, 400 = 5 tasks
rep_sis_cb <- matrix(rep(t(sis_cb), rep_num), ncol = ncol(sis_cb), byrow = T)
rep_sis_cb <- as.data.frame(rep_sis_cb)
colnames(rep_sis_cb) <- colnames(sis_cb)
i = 2
# load function
source("funcs/00_model_cluster.R")
# load data
base_vect <- c(2, 2, # SIS, BGM -- can comp with 4 for MBG
-1, -1, -1, 0.05, # 3-6 no enviro dep transmission
-1, -1, -1, 0.05, # 7-10 always dens dep transmission
0.05, 0.05, 0.05, # 11-13 + 17 background mort
1, 1, 1, # 14-16 + 18 disease mort
0.05, 0.05, # 17-18 mort sd
0.05, 0.05, 0.05, 0.05, # 19-22 recovery, unused bc SIX (1)
1.9, 2, 2.1, 0.05, 0.005, # 23-27 reproduction & mutation
100, 4, # 28-29 carrying capacity things
90, 2, # 30-32 timing things # note change from d = 1 to d = 2???
0.1, 0.1, 120) # init R and init disease, ngens
# #-----FIG1: STRUCTURALS-----
rep_sis_cb[i,]
cb_vect <- base_vect
cb_vect[35] <- as.numeric(rep_sis_cb$`number`[i])
cb_vect[1] <- as.numeric(rep_sis_cb$`compartment`[i]) # SIS or SIR
cb_vect[7:9] <- c(2, 2, 2) # density depend only
# benefit update
if (rep_sis_cb$case[i] == "\u03b2") {
cb_vect[7] <- as.numeric(cb_vect[9]*rep_sis_cb$`benefit`[i]) # sis_cb$benefit[cb]*cb_vect[8]
cb_vect[8] <- (cb_vect[7]+cb_vect[9])/2}
rep_sis_cb$`benefit`
rep_sis_cb$benefit[i]
cb_vect[9]*as.numeric(rep_sis_cb$`benefit`[i])
i
rep_sis_cb[i,]
cb_vect[9]
cb_vect <- base_vect
cb_vect[35] <- as.numeric(rep_sis_cb$`number`[i])
cb_vect[1] <- as.numeric(rep_sis_cb$`compartment`[i]) # SIS or SIR
cb_vect[7:9] <- c(2, 2, 2) # density depend only
# benefit update
if (rep_sis_cb$case[i] == "\u03b2") {
cb_vect[7] <- as.numeric(cb_vect[9]*as.numeric(rep_sis_cb$`benefit`[i])) # sis_cb$benefit[cb]*cb_vect[8]
cb_vect[8] <- (cb_vect[7]+cb_vect[9])/2}
if (rep_sis_cb$case[i] == "\u03bc") {
cb_vect[14] <- as.numeric(cb_vect[16]*as.numeric(rep_sis_cb$`benefit`[i])) # sis_cb$benefit[cb]*cb_vect[15]
cb_vect[15] <- (cb_vect[14]+cb_vect[16])/2}
if (rep_sis_cb$case[i] == "\u03d2") {
cb_vect[19] <- as.numeric(cb_vect[21]/as.numeric(rep_sis_cb$`benefit`[i])) # sis_cb$benefit[cb]*cb_vect[20]
cb_vect[20] <- (cb_vect[19]+cb_vect[21])/2}
# note for G, the meaning is opposite
# cost update -- not dependent on the case
cb_vect[23] <- as.numeric(rep_sis_cb$cost[i])
cb_vect[24] <- (cb_vect[23]+cb_vect[25])/2
cb_vect
cluster_run(cb_vect)
