geom_linerange(data = cb_summ_long_HL, aes(ymin = less, ymax = plus), lwd = 1) +
scale_color_manual(values = c("#ac1457", "#DB6341", "#f1c4a2")) +
facet_grid(rows = vars(outcome_f), cols = vars(transmission), scales = "free") +
