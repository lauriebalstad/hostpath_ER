p_ex <- ggplot(NULL, aes(x=as.factor(benefit), y=value, col = as.factor(cost))) +
geom_linerange(data = cb_summ_long %>% filter(outcome == "A - P(extinct)"), aes(ymin = less, ymax = plus), lwd = 1) +
geom_point(data = cb_summ_long %>% filter(outcome == "A - P(extinct)"), size = 2.5) +
scale_color_viridis(discrete = T, option = "rocket", begin = 0.5, end = 0.95) +
theme_classic() + theme(text = element_text(size = 12), legend.position = "bottom", axis.line=element_line()) + coord_cartesian(ylim = c(0, 0.65)) +
labs(x = NULL, col = "Allele fecundity", y = "Probability of extinction")
p_ex
p_er <- ggplot(NULL, aes(x=as.factor(benefit), y=value, col = as.factor(cost))) +
geom_linerange(data = cb_summ_long %>% filter(outcome == "B - P(rescue:\nevolutionary)"), aes(ymin = less, ymax = plus), lwd = 1) +
geom_point(data = cb_summ_long %>% filter(outcome == "B - P(rescue:\nevolutionary)"), size = 2.5) +
scale_color_viridis(discrete = T, option = "rocket", begin = 0.5, end = 0.95) +
theme_classic() + theme(text = element_text(size = 12), legend.position = "bottom", axis.line=element_line()) + coord_cartesian(ylim = c(0, 0.65)) +
labs(x = "Allele strength", col = "Allele fecundity", y = "Probability of ER")
p_er
plot_grid(p_ex + theme(legend.position = "none"),
p_er + theme(legend.position = "none"))
